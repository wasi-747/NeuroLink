{
  "name": "neurolink",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,client,ml -c blue,green,magenta \"npm run dev --prefix server\" \"npm run dev --prefix client\" \"cd ml-service && python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload\"",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "ml": "cd ml-service && python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload",
    "seed": "npm run seed --prefix server"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.16.0",
    "cookie-parser": "^1.4.7",
    "node-cron": "^4.2.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
